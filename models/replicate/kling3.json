{
  "provider": "replicate",
  "family": "Kling 3",
  "category": "Replicate/Video Generation",
  "nodes": [
    {
      "id": "replicate_kling3_txt2vid",
      "name": "Kling 3 (txt2vid)",
      "endpoint": "kwaivgi/kling-v3-video",
      "inputs": [
        { "name": "prompt", "data_type": "STRING", "api_field": "prompt", "required": true }
      ],
      "outputs": [
        { "name": "video", "data_type": "VIDEO", "api_field": "video" }
      ],
      "parameters": [
        { "name": "mode", "label": "Mode", "type": "enum", "api_field": "mode", "default": "standard", "options": ["standard", "pro"] },
        { "name": "aspect_ratio", "label": "Aspect Ratio", "type": "enum", "api_field": "aspect_ratio", "default": "16:9", "options": ["16:9", "9:16", "1:1"] },
        { "name": "duration", "label": "Duration", "type": "int", "api_field": "duration", "default": 5, "min": 3, "max": 15 },
        { "name": "generate_audio", "label": "Audio", "type": "bool", "api_field": "generate_audio", "default": true },
        { "name": "negative_prompt", "label": "Neg Prompt", "type": "enum", "api_field": "negative_prompt", "default": "", "options": [""] },
        { "name": "cfg_scale", "label": "CFG Scale", "type": "float", "api_field": "cfg_scale", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 }
      ]
    },
    {
      "id": "replicate_kling3_img2vid",
      "name": "Kling 3 (img2vid)",
      "endpoint": "kwaivgi/kling-v3-video",
      "inputs": [
        { "name": "prompt", "data_type": "STRING", "api_field": "prompt", "required": true },
        { "name": "start_image", "data_type": "IMAGE", "api_field": "start_image", "required": true },
        { "name": "end_image", "data_type": "IMAGE", "api_field": "end_image" }
      ],
      "outputs": [
        { "name": "video", "data_type": "VIDEO", "api_field": "video" }
      ],
      "ref_roles": [
        { "role": "start", "api_field": "start_image", "max": 1 },
        { "role": "end", "api_field": "end_image", "max": 1 }
      ],
      "parameters": [
        { "name": "mode", "label": "Mode", "type": "enum", "api_field": "mode", "default": "standard", "options": ["standard", "pro"] },
        { "name": "duration", "label": "Duration", "type": "int", "api_field": "duration", "default": 5, "min": 3, "max": 15 },
        { "name": "generate_audio", "label": "Audio", "type": "bool", "api_field": "generate_audio", "default": true },
        { "name": "negative_prompt", "label": "Neg Prompt", "type": "enum", "api_field": "negative_prompt", "default": "", "options": [""] },
        { "name": "cfg_scale", "label": "CFG Scale", "type": "float", "api_field": "cfg_scale", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 }
      ]
    }
  ]
}
